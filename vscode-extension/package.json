{
  "name": "living-docs-viewer-vscode",
  "displayName": "Living Docs Viewer",
  "description": "Visualize energimap-doc/v1 JSON files inside VS Code",
  "version": "0.1.0",
  "publisher": "michelzandonai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michelzandonai/living-docs-viewer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "activationEvents": [],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "livingDocs.docViewer",
        "displayName": "Living Docs Viewer",
        "selector": [
          { "filenamePattern": "*.json" }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "livingDocs.openPreview",
        "title": "Living Docs: Open Preview",
        "icon": {
          "light": "media/icon-light.svg",
          "dark": "media/icon-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .json",
          "command": "livingDocs.openPreview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:ext": "node esbuild.extension.mjs",
    "build:webview": "vite build --config vite.webview.config.ts",
    "build": "npm run build:ext && npm run build:webview",
    "watch:ext": "node esbuild.extension.mjs --watch",
    "package": "vsce package",
    "dev": "concurrently \"npm run watch:ext\" \"npm run build:webview -- --watch\""
  },
  "devDependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.0.0",
    "@xyflow/react": "^12.10.1",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "esbuild": "^0.24.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.4.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.3"
  }
}
