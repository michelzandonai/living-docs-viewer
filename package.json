{
  "name": "living-docs-viewer",
  "version": "0.4.1",
  "type": "module",
  "description": "React component library for viewing energimap-doc/v1 JSON documentation",
  "repository": {
    "type": "git",
    "url": "https://github.com/michelzandonai/living-docs-viewer.git"
  },
  "homepage": "https://github.com/michelzandonai/living-docs-viewer",
  "license": "MIT",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/living-docs-viewer.css",
    "./express": {
      "types": "./dist/server/middleware.d.ts",
      "import": "./dist/server/middleware.js",
      "require": "./dist/server/middleware.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "express": [
        "./dist/server/middleware.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "vite build --config vite.config.app.ts",
    "build:server": "tsup src/server/middleware.ts --format esm,cjs --dts --out-dir dist/server --external express",
    "build:all": "npm run build && npm run build:app && npm run build:server",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.4.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "express": "^5.2.1",
    "happy-dom": "^20.7.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.0.18"
  }
}
