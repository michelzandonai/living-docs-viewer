{
  "name": "@ajuri/living-docs-viewer",
  "version": "0.1.0",
  "type": "module",
  "description": "React component library for viewing energimap-doc/v1 JSON documentation",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css",
    "./express": {
      "types": "./dist/server/middleware.d.ts",
      "import": "./dist/server/middleware.js",
      "require": "./dist/server/middleware.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "express": ["./dist/server/middleware.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "vite build --config vite.config.app.ts",
    "build:server": "tsup src/server/middleware.ts --format esm,cjs --dts --out-dir dist/server --external express",
    "build:all": "npm run build && npm run build:app && npm run build:server",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "dependencies": {
    "zustand": "^5.0.3",
    "lucide-react": "^0.469.0",
    "mermaid": "^11.4.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "vite-plugin-dts": "^4.3.0"
  }
}
